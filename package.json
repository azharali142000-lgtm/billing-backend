{
  "name": "billing-backend",
  "version": "1.0.0",
  "description": "Production-ready Express backend for a billing application",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "build": "npm --prefix mobile-app install && npm --prefix mobile-app run build && node scripts/copy-mobile-dist.js",
    "dev": "nodemon src/server.js",
    "prestart": "npm run build",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^6.5.0"
  }
}
