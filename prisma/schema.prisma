generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WORKER
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum GstMode {
  ALL
  SELECTED_CUSTOMERS
}

enum GstType {
  CGST_SGST
  IGST
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  phone         String?        @unique
  email         String?        @unique
  firebaseUid   String?        @unique @map("firebase_uid")
  passwordHash  String?        @map("password_hash")
  role          UserRole
  isActive      Boolean        @default(true) @map("is_active")
  invoices     Invoice[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  tokenHash  String    @map("token_hash")
  deviceName String?   @map("device_name")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model Customer {
  id          Int       @id @default(autoincrement())
  name        String
  phone       String?   @unique
  address     String?
  gstSelected Boolean   @default(false) @map("gst_selected")
  balance     Decimal   @db.Decimal(12, 2) @default(0)
  creditLimit Decimal   @map("credit_limit") @db.Decimal(12, 2) @default(0)
  invoices    Invoice[]
  payments    Payment[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("customers")
}

model Product {
  id        Int           @id @default(autoincrement())
  name      String?
  price     Decimal       @db.Decimal(12, 2)
  gstRate   Decimal?      @map("gst_rate") @db.Decimal(5, 2)
  stock     Int           @default(0)
  items     InvoiceItem[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("products")
}

model Invoice {
  id         Int           @id @default(autoincrement())
  customerId Int           @map("customer_id")
  userId     Int           @map("user_id")
  subtotal   Decimal       @db.Decimal(12, 2) @default(0)
  gstApplied Boolean       @default(false) @map("gst_applied")
  gstRate    Decimal       @map("gst_rate") @db.Decimal(5, 2) @default(0)
  gstAmount  Decimal       @map("gst_amount") @db.Decimal(12, 2) @default(0)
  gstType    GstType?      @map("gst_type")
  gstNumber  String?       @map("gst_number")
  total      Decimal       @db.Decimal(12, 2)
  status     InvoiceStatus @default(PENDING)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  customer   Customer      @relation(fields: [customerId], references: [id])
  user       User          @relation(fields: [userId], references: [id])
  items      InvoiceItem[]

  @@index([createdAt])
  @@index([customerId])
  @@index([customerId, createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id        Int      @id @default(autoincrement())
  invoiceId Int      @map("invoice_id")
  productId Int      @map("product_id")
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("invoice_items")
}

model Payment {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  amount     Decimal  @db.Decimal(12, 2)
  method     String
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id])

  @@map("payments")
}

model GstSettings {
  id             Int      @id @default(1)
  gstEnabled     Boolean  @default(false) @map("gst_enabled")
  gstMode        GstMode  @default(ALL) @map("gst_mode")
  defaultGstRate Decimal  @default(18) @map("default_gst_rate") @db.Decimal(5, 2)
  gstNumber      String?  @map("gst_number")
  gstType        GstType  @default(CGST_SGST) @map("gst_type")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("gst_settings")
}

model CompanyProfile {
  id                 Int      @id @default(1)
  companyName        String   @map("company_name") @default("Billr Cloud")
  logoDataUrl        String?  @map("logo_data_url")
  address            String?  @db.Text
  phone              String?
  email              String?
  gstNumber          String?  @map("gst_number")
  bankDetails        String?  @map("bank_details") @db.Text
  termsAndConditions String?  @map("terms_and_conditions") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("company_profile")
}
