PORT=4000
NODE_ENV=development
APP_BASE_URL="https://app.billr.example"
FRONTEND_URL="https://app.billr.example"
API_BASE_URL="https://api.billr.example"
CORS_ORIGINS="https://app.billr.example,https://billr-mobile.vercel.app"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/billing_app?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
BCRYPT_SALT_ROUNDS=10
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@example.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
SEED_ADMIN_PHONE="9999999999"
SEED_ADMIN_PASSWORD="Admin@12345"
